# ---------------------------------------------------------------------------
# Bullseye Agent Configuration
#
# Copy this file to `.env` in the same directory and fill in the values.
# ---------------------------------------------------------------------------

# URL of the Bullseye central server (provided by your Bullseye contact).
# Use https:// in production; http:// is only for local testing.
BULLSEYE_SERVER_URL=https://your-bullseye-server

# API key for this agent. Provided by Bullseye when your agent was registered.
BULLSEYE_API_KEY=bse_your_api_key_here

# Telephony provider to use: "bandwidth", "twilio", "telnyx", "ringcentral",
# "asterisk", "freeswitch", or "proprietary"
TELEPHONY_PROVIDER=twilio


# ---------------------------------------------------------------------------
# Bandwidth credentials (required if TELEPHONY_PROVIDER=bandwidth)
# Create OAuth credentials in the Bandwidth dashboard:
#   Account → API Credentials → Create
# (Legacy username/password is supported but deprecated by Bandwidth — legacy
# API users will be decommissioned 2026-12-02. Use OAuth.)
# ---------------------------------------------------------------------------
# BANDWIDTH_ACCOUNT_ID=
# BANDWIDTH_CLIENT_ID=
# BANDWIDTH_CLIENT_SECRET=
# BANDWIDTH_APPLICATION_ID=
# BANDWIDTH_ANSWER_URL=https://your-bullseye-server/bandwidth/answer

# Legacy Basic Auth (deprecated, decommissioned 2026-12-02 — use OAuth above):
# BANDWIDTH_API_USERNAME=
# BANDWIDTH_API_PASSWORD=


# ---------------------------------------------------------------------------
# Twilio credentials (required if TELEPHONY_PROVIDER=twilio)
# Find these in the Twilio Console: https://console.twilio.com
# Use the main Account SID + primary Auth Token (not an API key).
# ---------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=


# ---------------------------------------------------------------------------
# Telnyx credentials (required if TELEPHONY_PROVIDER=telnyx)
# Requires a Voice API (Call Control) app with an assigned phone number.
# ---------------------------------------------------------------------------
# TELNYX_API_KEY=
# TELNYX_CONNECTION_ID=


# ---------------------------------------------------------------------------
# RingCentral credentials (required if TELEPHONY_PROVIDER=ringcentral)
# Requires a REST API app + JWT credential from the RingCentral admin portal.
# Also requires an "Other Phone" device on the extension (for SIP registration).
# See the installation guide for setup details.
#
# Docker: start with --profile ringcentral to run the SIP sidecar:
#   docker compose --profile ringcentral up -d --build
#
# Python: requires Node.js 18+ installed (the agent starts the sidecar automatically).
# ---------------------------------------------------------------------------
# RINGCENTRAL_CLIENT_ID=
# RINGCENTRAL_CLIENT_SECRET=
# RINGCENTRAL_JWT_TOKEN=
# RINGCENTRAL_SERVER_URL=https://platform.ringcentral.com
# RINGCENTRAL_SIDECAR_URL=http://127.0.0.1:3000


# ---------------------------------------------------------------------------
# Asterisk credentials (required if TELEPHONY_PROVIDER=asterisk)
# Works with Asterisk 13+ via ARI (Asterisk REST Interface). Requires
# res_ari + http server enabled on the Asterisk side. See
# providers/asterisk_provider.py for the full setup (ari.conf, http.conf,
# and a landing-pad dialplan context).
# ---------------------------------------------------------------------------
# ASTERISK_ARI_URL=http://asterisk-host:8088/ari
# ASTERISK_ARI_USERNAME=bullseye
# ASTERISK_ARI_PASSWORD=
# ASTERISK_ENDPOINT_TEMPLATE=PJSIP/{to_number}@my-trunk
# ASTERISK_CONTEXT=bullseye-landing
# ASTERISK_EXTENSION=s
# ASTERISK_DIAL_TIMEOUT=30


# ---------------------------------------------------------------------------
# FreeSWITCH credentials (required if TELEPHONY_PROVIDER=freeswitch)
# Uses ESL (Event Socket Library). Requires mod_event_socket loaded and
# event_socket.conf.xml bound to a reachable interface with a non-default
# password. See providers/freeswitch_provider.py for the full setup.
#
# ESL is unencrypted — keep traffic on a private network.
# ---------------------------------------------------------------------------
# FREESWITCH_HOST=freeswitch.local
# FREESWITCH_PORT=8021
# FREESWITCH_PASSWORD=
# FREESWITCH_ENDPOINT_TEMPLATE=sofia/gateway/my-provider/{to_number}
# FREESWITCH_DIAL_TIMEOUT=90


# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------
# Log verbosity: DEBUG, INFO (default), WARNING, ERROR
# LOG_LEVEL=INFO
