# ---------------------------------------------------------------------------
# Bullseye SBC sidecar — configuration.
#
# Copy to `.env` and fill in. The first four sections are SBC-specific
# (provided by your telecom team); the Bullseye Agent section is provided
# by Armor.
# ---------------------------------------------------------------------------


# ───── Bullseye Agent (provided by Armor) ──────────────────────────────────

BULLSEYE_SERVER_URL=https://your-bullseye-server
BULLSEYE_API_KEY=bse_your_api_key_here
TELEPHONY_PROVIDER=asterisk


# ───── SBC connection ──────────────────────────────────────────────────────

# Hostname or IP of the SBC. Must be reachable from this host.
SBC_HOST=sbc.example.com

# Signaling port — usually 5060 for UDP/TCP, 5061 for TLS.
SBC_PORT=5060

# Transport: udp, tcp, or tls. Match what the SBC accepts.
SBC_TRANSPORT=udp


# ───── SBC authentication ──────────────────────────────────────────────────

# If your SBC uses IP-based whitelisting (no SIP digest), leave SBC_USERNAME
# and SBC_PASSWORD empty — the SBC won't challenge and these go unused.
#
# If your SBC requires SIP digest auth, set both. They go into
# pjsip.conf as the outbound auth credentials.

SBC_USERNAME=
SBC_PASSWORD=

# What goes into the From: header. Most SBCs require a specific identity
# domain (your account, your trunk name, etc.) — ask your SBC admin.
SBC_FROM_USER=bullseye
SBC_FROM_DOMAIN=example.com


# ───── Bullseye agent → Asterisk (ARI) connection ──────────────────────────
# These don't leave the host; pick any strong password for ARI_PASSWORD.

ARI_PASSWORD=change-me-to-a-strong-password

# The agent's AsteriskProvider reads these:
ASTERISK_ARI_URL=http://127.0.0.1:8088/ari
ASTERISK_ARI_USERNAME=bullseye
# Reuse ARI_PASSWORD above:
ASTERISK_ARI_PASSWORD=${ARI_PASSWORD}

# Dial string template — sends calls to the SBC endpoint defined in pjsip.conf.
# Asterisk's PJSIP endpoint syntax is: PJSIP/<destination>@<endpoint-name>
ASTERISK_ENDPOINT_TEMPLATE=PJSIP/{to_number}@sbc

ASTERISK_CONTEXT=bullseye-landing
ASTERISK_EXTENSION=s
ASTERISK_DIAL_TIMEOUT=30

